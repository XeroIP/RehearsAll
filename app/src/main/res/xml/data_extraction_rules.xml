<?xml version="1.0" encoding="utf-8"?>
<!--
    Cloud backup rules (API 31+).
    Exclude large/regeneratable data, keep user preferences.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="." />
        <exclude domain="file" path="audio" />
        <exclude domain="file" path="waveforms" />
        <exclude domain="file" path="logs" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="logs" />
    </device-transfer>
</data-extraction-rules>
