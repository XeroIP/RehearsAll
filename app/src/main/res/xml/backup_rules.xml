<?xml version="1.0" encoding="utf-8"?>
<!--
    Android Auto Backup rules (API 23-30).
    Exclude large/regeneratable data, keep user preferences.
-->
<full-backup-content>
    <exclude domain="database" path="." />
    <exclude domain="file" path="audio" />
    <exclude domain="file" path="waveforms" />
    <exclude domain="file" path="logs" />
</full-backup-content>
